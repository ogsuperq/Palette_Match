# Palette Match v0.1 deployment environment
#
# This file contains placeholder values only. Never commit a populated .env file.
# Configure frontend variables in the Vercel project and backend variables in
# the backend hosting provider. Restart or redeploy after changing any value.


# =============================================================================
# FRONTEND - Vercel project settings
# =============================================================================

# REACT_APP_BACKEND_URL
# Purpose: Public origin of the deployed Palette Match backend. The frontend
# appends /api to this value for all API requests.
# Exposure: PUBLIC. Create React App embeds REACT_APP_* values in browser code.
# Hosting: Vercel frontend settings for Production, Preview, and Development.
# Requirements: Use HTTPS in production and do not include a trailing /api or
# trailing slash.
REACT_APP_BACKEND_URL=https://api.example.com


# =============================================================================
# BACKEND - backend hosting settings
# =============================================================================

# MONGO_URL
# Purpose: MongoDB connection string used by the API and session store.
# Exposure: SECRET. It normally contains database credentials.
# Hosting: Backend hosting settings only. Never expose this in Vercel frontend
# settings or prefix it with REACT_APP_.
# Requirements: Use a dedicated least-privilege production database user and
# require TLS in production.
MONGO_URL=mongodb+srv://placeholder_user:placeholder_password@placeholder-cluster.example.mongodb.net/?retryWrites=true&w=majority

# DB_NAME
# Purpose: Selects the MongoDB database containing Palette Match collections.
# Exposure: PUBLIC/NON-SECRET metadata, though it belongs only on the backend.
# Hosting: Backend hosting settings.
DB_NAME=palette_match_production

# EMERGENT_LLM_KEY
# Purpose: Authenticates backend AI matching requests made through the
# emergentintegrations LLM client.
# Exposure: SECRET.
# Hosting: Backend hosting settings only.
EMERGENT_LLM_KEY=placeholder_llm_api_key

# CORS_ORIGINS
# Purpose: Comma-separated list of browser origins allowed to call the API with
# credentials. Include each exact Vercel production or approved preview origin.
# Exposure: PUBLIC/NON-SECRET configuration.
# Hosting: Backend hosting settings.
# Requirements: Do not use * because credentialed session cookies are enabled.
# Do not include paths or trailing slashes.
CORS_ORIGINS=https://app.example.com,https://preview.example.com

# CORS_ORIGIN_REGEX
# Purpose: Optionally permits dynamic Vercel preview origins that belong only
# to this frontend project and Vercel scope. Leave unset when using one exact,
# stable Vercel branch URL in CORS_ORIGINS.
# Exposure: PUBLIC/NON-SECRET configuration.
# Hosting: Backend hosting settings.
# Requirements: Scope both the project and account/team slug. Never use a broad
# expression such as ^https://.*\.vercel\.app$.
CORS_ORIGIN_REGEX=^https://palette-match-(?:git-[a-z0-9-]+|[a-z0-9]{9})-your-vercel-scope\.vercel\.app$

# ALLOW_DEMO_SEED
# Purpose: Enables the demo-data seed endpoint and automatic demo artist
# insertion into an empty database.
# Exposure: PUBLIC/NON-SECRET configuration.
# Hosting: Backend hosting settings.
# Production value: Must remain false for a real v0.1 deployment.
ALLOW_DEMO_SEED=false


# =============================================================================
# OPTIONAL FRONTEND BUILD/OPERATIONS SETTINGS
# =============================================================================

# ENABLE_HEALTH_CHECK
# Purpose: Enables the frontend development health-check plugin.
# Exposure: PUBLIC/NON-SECRET build configuration.
# Hosting: Vercel frontend settings only if that plugin is intentionally needed.
# Production value: Normally false.
ENABLE_HEALTH_CHECK=false


# =============================================================================
# AUTHENTICATION AND SESSION NOTES
# =============================================================================

# Palette Match v0.1 currently uses the Emergent hosted OAuth flow. Its frontend
# login URL and backend session-exchange URL are fixed in application code, so
# there are no authentication-provider environment variables to configure.
#
# The provider returns the session token. The backend stores that opaque token
# in MongoDB and sends it in a Secure, HttpOnly, SameSite=None cookie. The app
# does not generate or sign JWTs, so AUTH_SECRET, JWT_SECRET, and SESSION_SECRET
# are not currently read or required. Do not invent placeholder secrets under
# those names: they would provide no protection unless the authentication
# implementation is changed to consume them.
#
# Production authentication still requires:
# - The deployed frontend callback origin to be allowed by the OAuth provider.
# - REACT_APP_BACKEND_URL to point to the production HTTPS API.
# - CORS_ORIGINS to contain the exact deployed frontend origin.
# - CORS_ORIGIN_REGEX to be narrowly scoped if dynamic previews are enabled.
# - MongoDB to be available because sessions are persisted in user_sessions.
